# Medicaid FWA Analytics Pipeline — Environment Configuration
# Copy to .env and fill in values for your environment.

# Environment: development | staging | production
MEDICAID_ENV=development

# Database
DB_PATH=medicaid.duckdb
DB_THREADS=16
DB_MEMORY_LIMIT=96GB

# Data source
CSV_PATH=medicaid-provider-spending.csv

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Pipeline execution
MAX_WORKERS=10
HALT_ON_FAILURE=true

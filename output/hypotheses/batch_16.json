  {
    "id": "H0831",
    "category": "8",
    "subcategory": "8A",
    "description": "Impossible volume: T1019 > 480 units/bene/month",
    "method": "impossible_volume",
    "acceptance_criteria": "claims/bene exceeds physical max of 480",
    "sql_template": "\n                SELECT billing_npi, claim_month, claims, beneficiaries, paid,\n                       claims * 1.0 / NULLIF(beneficiaries, 0) AS claims_per_bene\n                FROM claims WHERE hcpcs_code = 'T1019' AND beneficiaries > 0\n                  AND claims * 1.0 / beneficiaries > 480 AND paid > 10000\n                ORDER BY paid DESC LIMIT 50\n            ",
    "financial_impact_method": "100% of payments above physical maximum",
    "parameters": {
      "hcpcs_code": "T1019",
      "unit_minutes": 15,
      "max_units": 480
    }
  },

[
  {
    "id": "H0314",
    "category": "3",
    "subcategory": "3B",
    "description": "Total claims > 10x peer median for 99203",
    "method": "peer_volume",
    "acceptance_criteria": "> 10x peer median, >= 12 months, > $100K",
    "sql_template": "\n                WITH code_peers AS (\n                    SELECT PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY claims) AS median_claims\n                    FROM provider_hcpcs WHERE hcpcs_code = '99203' AND months_active >= 12\n                )\n                SELECT ph.billing_npi, ph.claims, ph.paid, ph.months_active,\n                       ph.claims / NULLIF(cp.median_claims, 0) AS ratio\n                FROM provider_hcpcs ph CROSS JOIN code_peers cp\n                WHERE ph.hcpcs_code = '99203' AND ph.months_active >= 12 AND ph.paid > 100000\n                  AND ph.claims > 10 * cp.median_claims\n                ORDER BY ph.paid DESC LIMIT 50\n            ",
    "financial_impact_method": "(provider_claims - peer_median_claims) * peer_median_rate",
    "parameters": {
      "hcpcs_code": "99203",
      "ratio_threshold": 10.0,
      "min_months": 12,
      "min_paid": 100000
    }
  },
